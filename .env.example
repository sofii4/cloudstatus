# PostgreSQL
POSTGRES_USER=cloudstatus
POSTGRES_PASSWORD=changeme_immediately_in_production
POSTGRES_DB=cloudstatus_db
DATABASE_URL=postgresql://cloudstatus:changeme_immediately_in_production@db:5432/cloudstatus_db

# Redis
REDIS_URL=redis://redis:6379/0

# App
SECRET_KEY=generate-a-strong-secret-key-here-and-change-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password_in_production

# Polling interval (segundos)
POLL_INTERVAL=60

# CORS Origins (comma-separated)
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:3000

# Logging
LOG_LEVEL=INFO
